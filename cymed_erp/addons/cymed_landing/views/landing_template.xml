        </t>
    </template>

    <!-- ── Demo Request Form ──────────────────────────────────────────────── -->
    <template id="demo_request_form" name="CyMed Demo Request">
        <t t-call="website.layout">
            <div class="cymed-form-page">
                <div class="cymed-container cymed-form-container">
                    <h1>Request a Demo</h1>
                    <p>See how CyMed handles your specific healthcare operations. We'll be in touch within 24 hours.</p>
                    <form action="/submit-demo-request" method="post" class="cymed-form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="cymed-form-grid">
                            <div class="cymed-form-field">
                                <label>Your Name <span>*</span></label>
                                <input type="text" name="name" required="required"/>
                            </div>
                            <div class="cymed-form-field">
                                <label>Organization <span>*</span></label>
                                <input type="text" name="organization" required="required"/>
                            </div>
                            <div class="cymed-form-field">
                                <label>Work Email <span>*</span></label>
                                <input type="email" name="email" required="required"/>
                            </div>
                            <div class="cymed-form-field">
                                <label>Phone</label>
                                <input type="tel" name="phone"/>
                            </div>
                            <div class="cymed-form-field cymed-form-field-full">
                                <label>What would you like to see?</label>
                                <textarea name="notes" rows="4" placeholder="Modules of interest, scale of operation, timeline..."></textarea>
                            </div>
                        </div>
                        <button type="submit" class="cymed-btn cymed-btn-primary cymed-btn-lg">Send Request</button>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <template id="demo_request_thanks" name="CyMed Demo Request Thanks">
        <t t-call="website.layout">
            <div class="cymed-thanks-page">
                <div class="cymed-container">
                    <h1>✓ Got it.</h1>
                    <p>Thank you for your interest in CyMed. A healthcare specialist will reach out within 24 business hours.</p>
                    <a href="/" class="cymed-btn cymed-btn-primary">Back to Home</a>
                </div>
            </div>
        </t>
    </template>
</odoo>
