<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override the browser tab title and meta -->
    <template id="cymed_webclient_title" inherit_id="web.webclient_bootstrap" name="CyMed Webclient">
        <xpath expr="//title" position="replace">
            <title>CyMed ERP</title>
        </xpath>
    </template>

    <!-- Override the "Powered by" footer in reports -->
    <template id="cymed_external_layout" inherit_id="web.external_layout_standard" name="CyMed Report Layout">
        <xpath expr="//div[hasclass('text-muted')][last()]" position="replace">
            <div class="text-muted">
                <span>Generated by CyMed ERP — </span>
                <span t-esc="datetime.datetime.now().strftime('%Y-%m-%d %H:%M')"/>
            </div>
        </xpath>
    </template>
</odoo>
