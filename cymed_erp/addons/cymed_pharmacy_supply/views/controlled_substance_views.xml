<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cs_log_list" model="ir.ui.view">
        <field name="name">cymed.cs.log.list</field>
        <field name="model">cymed.controlled.substance.log</field>
        <field name="arch" type="xml">
            <list decoration-danger="discrepancy != 0">
                <field name="reference"/>
                <field name="log_date"/>
                <field name="drug_id"/>
                <field name="schedule"/>
                <field name="movement_type"/>
                <field name="quantity"/>
                <field name="lot_id"/>
                <field name="patient_id"/>
                <field name="handler_id"/>
                <field name="witness_id"/>
                <field name="biometric_verified" widget="boolean"/>
                <field name="discrepancy"/>
            </list>
        </field>
    </record>

    <record id="view_cs_log_form" model="ir.ui.view">
        <field name="name">cymed.cs.log.form</field>
        <field name="model">cymed.controlled.substance.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="reference"/></h1></div>
                    <group>
                        <group>
                            <field name="log_date"/>
                            <field name="drug_id"/>
                            <field name="schedule" readonly="1"/>
                            <field name="movement_type"/>
                        </group>
                        <group>
                            <field name="lot_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                        </group>
                    </group>
                    <group string="Patient &amp; Source/Destination">
                        <group>
                            <field name="patient_id"/>
                            <field name="prescription_id"/>
                            <field name="source_location_id"/>
                            <field name="dest_location_id"/>
                        </group>
                        <group>
                            <field name="handler_id"/>
                            <field name="witness_id"/>
                            <field name="biometric_verified"/>
                        </group>
                    </group>
                    <group string="Balance Check">
                        <group>
                            <field name="balance_before"/>
                            <field name="balance_after"/>
                            <field name="discrepancy" decoration-danger="discrepancy != 0"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_cs_log" model="ir.actions.act_window">
        <field name="name">Controlled Substance Register</field>
        <field name="res_model">cymed.controlled.substance.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Reconciliation -->
    <record id="view_cs_recon_list" model="ir.ui.view">
        <field name="name">cymed.cs.recon.list</field>
        <field name="model">cymed.controlled.substance.reconciliation</field>
        <field name="arch" type="xml">
            <list decoration-danger="total_discrepancy &gt; 0">
                <field name="name"/>
                <field name="date"/>
                <field name="shift"/>
                <field name="location_id"/>
                <field name="pharmacist_id"/>
                <field name="total_discrepancy"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_cs_recon_form" model="ir.ui.view">
        <field name="name">cymed.cs.recon.form</field>
        <field name="model">cymed.controlled.substance.reconciliation</field>
        <field name="arch" type="xml">
            <form>
                <header><field name="state" widget="statusbar"/></header>
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="shift"/>
                            <field name="location_id"/>
                        </group>
                        <group>
                            <field name="pharmacist_id"/>
                            <field name="supervisor_id"/>
                            <field name="total_discrepancy" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom" decoration-danger="discrepancy != 0">
                            <field name="drug_id"/>
                            <field name="expected_qty"/>
                            <field name="physical_qty"/>
                            <field name="discrepancy" readonly="1"/>
                            <field name="reason"/>
                        </list>
                    </field>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_cs_recon" model="ir.actions.act_window">
        <field name="name">Shift Reconciliations</field>
        <field name="res_model">cymed.controlled.substance.reconciliation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
