<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">
    <record id="fs_active" model="cymed.formulary.status">
        <field name="name">Active</field><field name="code">active</field>
        <field name="sequence">10</field><field name="allow_dispensing" eval="True"/>
    </record>
    <record id="fs_restricted" model="cymed.formulary.status">
        <field name="name">Restricted (Approval Required)</field><field name="code">restricted</field>
        <field name="sequence">20</field><field name="allow_dispensing" eval="True"/><field name="requires_approval" eval="True"/>
    </record>
    <record id="fs_non_formulary" model="cymed.formulary.status">
        <field name="name">Non-Formulary</field><field name="code">non_formulary</field>
        <field name="sequence">30</field><field name="allow_dispensing" eval="False"/><field name="requires_approval" eval="True"/>
    </record>
    <record id="fs_discontinued" model="cymed.formulary.status">
        <field name="name">Discontinued</field><field name="code">discontinued</field>
        <field name="sequence">90</field><field name="allow_dispensing" eval="False"/>
    </record>
</data></odoo>
