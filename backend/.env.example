APP_NAME=CyMed
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
API_VERSION=1.0.0
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cymed
DB_USERNAME=postgres
DB_PASSWORD=

DB_SCHEMA=public

CACHE_STORE=redis
CACHE_PREFIX=cymed_

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@cymed.health"
MAIL_FROM_NAME="${APP_NAME}"

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# FHIR Configuration
FHIR_BASE_URL="${APP_URL}/fhir/r4"
FHIR_VERSION=R4

# AI Configuration
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Insurance / NPHIES (Saudi Arabia)
NPHIES_BASE_URL=https://HSB.nphies.sa
NPHIES_PAYER_ID=
NPHIES_PROVIDER_NPI=
NPHIES_CLIENT_ID=
NPHIES_CLIENT_SECRET=

# SMS Gateway
SMS_PROVIDER=unifonic
SMS_API_KEY=
SMS_SENDER_ID=CyMed

# WhatsApp
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# MFA
MFA_ENABLED=true
MFA_ISSUER=CyMed

# Audit
AUDIT_DRIVER=elasticsearch
ELASTICSEARCH_HOST=127.0.0.1:9200

# Hospital Configuration
HOSPITAL_NAME="CyMed Medical Center"
HOSPITAL_FACILITY_ID=
HOSPITAL_LICENSE_NUMBER=
HOSPITAL_TIMEZONE=Asia/Riyadh
HOSPITAL_CURRENCY=SAR
HOSPITAL_COUNTRY=SA

# ZATCA e-Invoicing (Saudi Arabia)
ZATCA_VAT_NUMBER=
ZATCA_ENV=sandbox

# Encryption keys for PHI
PHI_ENCRYPTION_KEY=
