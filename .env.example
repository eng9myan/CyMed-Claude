# CyMed Environment Variables
# Copy this file to .env and fill in all values before running

# Database
POSTGRES_USER=cymed
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=cymed_db

# Django / Python Backend
SECRET_KEY=generate_with_python_-c_"import_secrets;print(secrets.token_hex(50))"
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# AI / Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Storage (AWS S3 or MinIO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=cymed-storage
AWS_S3_REGION_NAME=me-south-1

# Monitoring
SENTRY_DSN=

# NPHIES (Saudi National Platform for Health Insurance Exchange)
NPHIES_BASE_URL=
NPHIES_CLIENT_ID=
NPHIES_CLIENT_SECRET=

# ZATCA (Saudi e-Invoicing)
ZATCA_CERT=
ZATCA_PRIVATE_KEY=
